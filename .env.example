# KubeAgent Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─────────────────────────────────────────
# Anthropic (Required)
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5

# ─────────────────────────────────────────
# Kubeflow Pipelines (Required)
# ─────────────────────────────────────────
KFP_ENDPOINT=http://localhost:8887
KFP_NAMESPACE=kubeflow
# KFP_TOKEN=                        # Optional: bearer token for auth-enabled KFP

# ─────────────────────────────────────────
# MLflow (Required)
# ─────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─────────────────────────────────────────
# GitHub (Required for PR creation)
# ─────────────────────────────────────────
# Create a PAT at: https://github.com/settings/tokens
# Required scopes: repo (full)
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_REPO=your-username/your-repo-name
GITHUB_BASE_BRANCH=main

# ─────────────────────────────────────────
# Kubernetes
# ─────────────────────────────────────────
K8S_IN_CLUSTER=false               # Set to true when running inside a pod
K8S_NAMESPACE=kubeflow
# KUBECONFIG=~/.kube/config        # Optional: explicit kubeconfig path

# ─────────────────────────────────────────
# Agent Behaviour
# ─────────────────────────────────────────
POLL_INTERVAL_SECONDS=300          # How often to poll KFP (seconds)
LOOKBACK_HOURS=1                   # How far back to look for failed runs
MAX_TOOL_ITERATIONS=10             # Max Claude tool_use turns per run
MEMORY_PATH=memory/agent_memory.json
REPORTS_DIR=reports

# ─────────────────────────────────────────
# Slack Notifications (Optional)
# ─────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
